# লাইন ১: আমাদের অ্যাপের জন্য একটি অফিশিয়াল ও লাইটওয়েট পাইথন বেস ইমেজ নিচ্ছি
FROM python:3.10-slim

# লাইন ২: কন্টেইনারের ভেতরে কোন ফোল্ডারে কোড থাকবে, তা ফিক্স করছি। 
# এরপর সব কাজ এই /app ফোল্ডারের ভেতর ঘটবে।
WORKDIR /app

# লেইন ৩: লোকাল পিসি থেকে requirements.txt ফাইলটি কন্টেইনারের /app ফোল্ডারে কপি করছি।
COPY requirements.txt .

# লাইন ৪: কন্টেইনারের ভেতরে পাইথনের প্যাকেজগুলো ইনস্টল করছি।
# --no-cache-dir দিলে ইমেজের সাইজ ছোট থাকে, ফালতু ক্যাশ জমেনি।
RUN pip install --no-cache-dir -r requirements.txt

# লাইন ৫: আপনার লোকাল ফোল্ডারের বাকি সব কোড (যেমন main.py) কন্টেইনারের ভেতরে কপি করে নিচ্ছি।
COPY . .

# লাইন ৬: কন্টেইনারটি বাইরের দুনিয়ার সাথে কথা বলার জন্য কোন পোর্ট ওপেন রাখবে, তা ডিক্লেয়ার করছি।
EXPOSE 8000

# লাইন ৭: কন্টেইনারটি চালু হওয়ার ঠিক মুহূর্তে কোন কমান্ডটি রান করবে, তা বলে দিচ্ছি।
# --host 0.0.0.0 না দিলে কন্টেইনারের বাইরের ট্রাফিক ভেতরে ঢুকতে পারে না।
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]